MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PUBLIC_BASE_URL=https://mail-mcp.example.com
MCP_INTERNAL_HTTPS=false
MCP_ALLOW_SELF_SIGNED_INTERNAL_HTTPS=false
MCP_TLS_CERT_FILE=
MCP_TLS_KEY_FILE=
MCP_DEBUG_UNREDACTED_LOGS=false

APP_DATA_DIR=/var/lib/imap-smtp-mcp
OAUTH_STORE_PATH=/var/lib/imap-smtp-mcp/oauth.sqlite3

OAUTH_ISSUER=https://mail-mcp.example.com
OAUTH_AUDIENCE=https://mail-mcp.example.com
OAUTH_SIGNING_KEY=replace-with-long-random-signing-secret
OAUTH_COOKIE_SECRET=replace-with-long-random-csrf-cookie-signing-secret
OAUTH_DEV_INSECURE_SECRETS=false
# Generate with:
# python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
OAUTH_ENCRYPTION_KEY=replace-with-fernet-key
OAUTH_REQUIRED_SCOPES=mail:read mail:send mail:write
OAUTH_ALLOWED_REDIRECT_URI_PATTERNS=https://chatgpt\.com/connector/oauth/cb
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
OAUTH_AUTH_CODE_TTL_SECONDS=300
OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
OAUTH_AUTHORIZE_RATE_LIMIT_ATTEMPTS=5
OAUTH_AUTHORIZE_RATE_LIMIT_WINDOW_SECONDS=900
OAUTH_REGISTER_RATE_LIMIT_ATTEMPTS=20
OAUTH_REGISTER_RATE_LIMIT_WINDOW_SECONDS=900
OAUTH_RATE_LIMIT_MAX_BUCKETS=10000
OAUTH_AUTHORIZE_CSRF_MAX_TOKENS=5000

IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_MODE=ssl
IMAP_SENT_FOLDER=Sent
IMAP_TRASH_FOLDER=Trash
IMAP_TLS_VERIFY=true
IMAP_TLS_CA_BUNDLE_PATH=/run/secrets/imap-ca.pem
IMAP_MAX_RETRIES=2

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_MODE=starttls
SMTP_FROM_DOMAIN=example.com
SMTP_TIMEOUT_SECONDS=30

MCP_ATTACHMENT_MAX_COUNT=10
MCP_ATTACHMENT_MAX_BYTES=1048576
MCP_ATTACHMENT_BLOCKED_MIME_TYPES=text/html,text/javascript,text/ecmascript,application/javascript,application/ecmascript
MCP_ATTACHMENT_BLOCKED_EXTENSIONS=.html,.htm,.js,.mjs

ACTION_LIST_FOLDERS=true
ACTION_SEARCH_EMAILS=true
ACTION_LIST_EMAILS=true
ACTION_READ_EMAIL=true
ACTION_SEND_EMAIL=true
ACTION_MARK_READ_STATE=false
ACTION_MOVE_EMAIL=false
ACTION_COPY_EMAIL=false
ACTION_DELETE_EMAIL_PERMANENT=false
ACTION_MOVE_TO_TRASH=false
ACTION_EMPTY_TRASH=false
ACTION_CREATE_FOLDER=false
ACTION_RENAME_FOLDER=false
ACTION_DELETE_FOLDER=false

AUDIT_LOG_DIR=/var/lib/imap-smtp-mcp/audit
